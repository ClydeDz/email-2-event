{
  "manifest_version": 3,
  "name": "Email 2 Event",
  "version": "0.9.0",
  "description": "Create Google Calendar events from Gmail emails using on-device AI.",
  "permissions": [
    "storage",
    "identity",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://mail.google.com/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "src/content/gmail.ts"
      ],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/landing/dashboard.html",
  "action": {
    "default_title": "Email 2 Event",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "oauth2": {
    "client_id": "$OAUTH_CLIENT_ID",
    "scopes": [
      "openid",
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/tasks"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/modal.css"
      ],
      "matches": [
        "https://mail.google.com/*"
      ]
    },
    {
      "resources": [
        "icons/icon.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "minimum_chrome_version": "138"
}